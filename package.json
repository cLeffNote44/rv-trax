{
  "name": "rv-trax",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time asset tracking system for RV dealerships",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@rv-trax/db",
    "db:migrate": "turbo run db:migrate --filter=@rv-trax/db",
    "db:seed": "turbo run db:seed --filter=@rv-trax/db",
    "db:studio": "turbo run db:studio --filter=@rv-trax/db",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.38.0"
    }
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
