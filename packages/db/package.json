    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0",
    "@rv-trax/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
