{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "RV Trax — Overview",
  "uid": "rvtrax-overview",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "HTTP Requests / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(rvtrax_http_requests_total[1m]) * 60",
          "legendFormat": "requests/min"
        }
      ]
    },
    {
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(rvtrax_http_errors_total[5m]) / rate(rvtrax_http_requests_total[5m]) * 100",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "title": "Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rvtrax_http_request_duration_ms_avg",
          "legendFormat": "avg ms"
        },
        {
          "expr": "rvtrax_http_request_duration_ms_p99",
          "legendFormat": "p99 ms"
        }
      ]
    },
    {
      "title": "WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rvtrax_ws_active_connections",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "WebSocket Rooms",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "rvtrax_ws_active_rooms",
          "legendFormat": "rooms"
        }
      ]
    },
    {
      "title": "IoT Events Processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(rvtrax_iot_events_processed_total[5m]) * 60",
          "legendFormat": "events/min"
        }
      ]
    },
    {
      "title": "IoT Pipeline Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rvtrax_iot_queue_depth",
          "legendFormat": "queue depth"
        }
      ]
    },
    {
      "title": "Server Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rvtrax_uptime_seconds / 3600",
          "legendFormat": "hours"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h"
        }
      }
    }
  ]
}
